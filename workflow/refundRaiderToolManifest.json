{
  "intakeToolNames": [
    "get_intake_state",
    "update_intake_fields",
    "capture_user_problem",
    "connect_gmail",
    "search_gmail_messages",
    "select_gmail_message",
    "create_case"
  ],
  "caseToolNames": [
    "lookup_policy_evidence",
    "summarize_eligibility",
    "create_refund_draft",
    "send_refund_email",
    "get_case_status",
    "build_action_plan",
    "request_user_consent",
    "execute_case_action",
    "schedule_follow_up",
    "firecrawl_extract",
    "firecrawl_get_extract_status",
    "firecrawl_start_crawl",
    "firecrawl_get_crawl_status"
  ],
  "browserToolNames": [
    "start_browser_session",
    "browser_snapshot",
    "browser_navigate",
    "browser_click",
    "browser_type",
    "browser_scroll",
    "browser_wait_for_text",
    "browser_extract",
    "browser_press_key"
  ],
  "tools": [
    {
      "name": "get_intake_state",
      "description": "Return the current intake state so the live agent knows what is already collected.",
      "parameters": {
        "type": "object",
        "properties": {},
        "required": []
      }
    },
    {
      "name": "update_intake_fields",
      "description": "Update structured intake fields in the UI when the user gives explicit details.",
      "parameters": {
        "type": "object",
        "properties": {
          "merchantName": { "type": "string", "description": "Merchant name" },
          "merchantUrl": { "type": "string", "description": "Merchant URL" },
          "issueSummary": { "type": "string", "description": "Issue summary" },
          "issueType": {
            "type": "string",
            "description": "Issue type",
            "enum": ["damaged_item", "missing_item", "wrong_item", "late_delivery", "service_not_rendered", "subscription_cancellation", "other"]
          },
          "desiredOutcome": {
            "type": "string",
            "description": "Desired outcome",
            "enum": ["full_refund", "partial_refund", "replacement", "refund_or_replacement"]
          },
          "purchaseDate": { "type": "string", "description": "Purchase date" },
          "paymentMethod": {
            "type": "string",
            "description": "Payment method",
            "enum": ["credit_card", "debit_card", "paypal", "apple_pay", "shop_pay", "other", "unknown"]
          },
          "merchantContactEmail": { "type": "string", "description": "Merchant support email" }
        },
        "required": []
      }
    },
    {
      "name": "capture_user_problem",
      "description": "Parse a messy natural-language problem statement or pasted email into structured intake.",
      "parameters": {
        "type": "object",
        "properties": {
          "rawText": { "type": "string", "description": "The raw problem statement or pasted context" }
        },
        "required": ["rawText"]
      }
    },
    {
      "name": "connect_gmail",
      "description": "Start the Gmail OAuth flow when the user agrees to connect their inbox.",
      "parameters": {
        "type": "object",
        "properties": {},
        "required": []
      }
    },
    {
      "name": "search_gmail_messages",
      "description": "Search connected Gmail for receipts, renewals, or support threads.",
      "parameters": {
        "type": "object",
        "properties": {
          "query": { "type": "string", "description": "Search query for Gmail" }
        },
        "required": ["query"]
      }
    },
    {
      "name": "select_gmail_message",
      "description": "Use a specific Gmail message search result to populate the intake.",
      "parameters": {
        "type": "object",
        "properties": {
          "messageId": { "type": "string", "description": "Gmail message ID" }
        },
        "required": ["messageId"]
      }
    },
    {
      "name": "create_case",
      "description": "Create the case once intake is complete enough to proceed.",
      "parameters": {
        "type": "object",
        "properties": {},
        "required": []
      }
    },
    {
      "name": "lookup_policy_evidence",
      "description": "Trigger or refresh policy and support research for a case.",
      "parameters": {
        "type": "object",
        "properties": {
          "caseId": { "type": "string", "description": "Case ID" },
          "forceRefresh": { "type": "boolean", "description": "Refresh cached research" }
        },
        "required": ["caseId"]
      }
    },
    {
      "name": "summarize_eligibility",
      "description": "Return the current eligibility verdict and recommended path for a case.",
      "parameters": {
        "type": "object",
        "properties": {
          "caseId": { "type": "string", "description": "Case ID" }
        },
        "required": ["caseId"]
      }
    },
    {
      "name": "create_refund_draft",
      "description": "Generate a refund email draft from the active strategy.",
      "parameters": {
        "type": "object",
        "properties": {
          "caseId": { "type": "string", "description": "Case ID" },
          "tone": {
            "type": "string",
            "description": "Draft tone",
            "enum": ["firm_polite", "neutral", "escalation_ready"]
          }
        },
        "required": ["caseId"]
      }
    },
    {
      "name": "send_refund_email",
      "description": "Send the approved refund draft to the merchant support address.",
      "parameters": {
        "type": "object",
        "properties": {
          "caseId": { "type": "string", "description": "Case ID" },
          "draftId": { "type": "string", "description": "Draft ID" },
          "to": {
            "type": "array",
            "description": "Email recipients",
            "items": { "type": "string", "description": "Recipient email address" }
          },
          "ccUser": { "type": "boolean", "description": "Whether to cc the user" }
        },
        "required": ["caseId", "draftId", "to"]
      }
    },
    {
      "name": "get_case_status",
      "description": "Return the current case state for conversational continuity.",
      "parameters": {
        "type": "object",
        "properties": {
          "caseId": { "type": "string", "description": "Case ID" }
        },
        "required": ["caseId"]
      }
    },
    {
      "name": "build_action_plan",
      "description": "Translate the evidence-backed verdict into executable case actions.",
      "parameters": {
        "type": "object",
        "properties": {
          "caseId": { "type": "string", "description": "Case ID" }
        },
        "required": ["caseId"]
      }
    },
    {
      "name": "request_user_consent",
      "description": "Request user approval before a sensitive action runs.",
      "parameters": {
        "type": "object",
        "properties": {
          "actionId": { "type": "string", "description": "Action run ID" }
        },
        "required": ["actionId"]
      }
    },
    {
      "name": "execute_case_action",
      "description": "Run the next planned action for the case or ops fallback lane.",
      "parameters": {
        "type": "object",
        "properties": {
          "actionId": { "type": "string", "description": "Action run ID" }
        },
        "required": ["actionId"]
      }
    },
    {
      "name": "schedule_follow_up",
      "description": "Create a follow-up task when the merchant has not replied yet.",
      "parameters": {
        "type": "object",
        "properties": {
          "caseId": { "type": "string", "description": "Case ID" },
          "title": { "type": "string", "description": "Optional follow-up title" }
        },
        "required": ["caseId"]
      }
    },
    {
      "name": "firecrawl_extract",
      "description": "Ask Firecrawl to extract structured support or policy details from one or more URLs.",
      "parameters": {
        "type": "object",
        "properties": {
          "urls": {
            "type": "array",
            "description": "URLs to extract from",
            "items": { "type": "string", "description": "Target URL" }
          },
          "prompt": { "type": "string", "description": "Extraction prompt" }
        },
        "required": ["urls", "prompt"]
      }
    },
    {
      "name": "firecrawl_get_extract_status",
      "description": "Check the status of a Firecrawl extract job.",
      "parameters": {
        "type": "object",
        "properties": {
          "extractId": { "type": "string", "description": "Firecrawl extract job ID" }
        },
        "required": ["extractId"]
      }
    },
    {
      "name": "firecrawl_start_crawl",
      "description": "Start a Firecrawl crawl for deeper support-path discovery.",
      "parameters": {
        "type": "object",
        "properties": {
          "url": { "type": "string", "description": "Seed URL to crawl" },
          "prompt": { "type": "string", "description": "Optional crawl guidance prompt" },
          "limit": { "type": "number", "description": "Maximum pages to crawl" }
        },
        "required": ["url"]
      }
    },
    {
      "name": "firecrawl_get_crawl_status",
      "description": "Check the status of a Firecrawl crawl job.",
      "parameters": {
        "type": "object",
        "properties": {
          "crawlId": { "type": "string", "description": "Firecrawl crawl job ID" }
        },
        "required": ["crawlId"]
      }
    },
    {
      "name": "start_browser_session",
      "description": "Create or reuse a browser automation session for the current case.",
      "parameters": {
        "type": "object",
        "properties": {
          "caseId": { "type": "string", "description": "Case ID" }
        },
        "required": ["caseId"]
      }
    },
    {
      "name": "browser_snapshot",
      "description": "Capture the current browser title, URL, and visible text for context.",
      "parameters": {
        "type": "object",
        "properties": {
          "selector": { "type": "string", "description": "Optional selector to scope the snapshot" }
        },
        "required": []
      }
    },
    {
      "name": "browser_navigate",
      "description": "Open a supported URL in the browser runtime.",
      "parameters": {
        "type": "object",
        "properties": {
          "targetUrl": { "type": "string", "description": "Target URL" }
        },
        "required": ["targetUrl"]
      }
    },
    {
      "name": "browser_click",
      "description": "Click a browser element identified by a selector.",
      "parameters": {
        "type": "object",
        "properties": {
          "selector": { "type": "string", "description": "CSS selector" }
        },
        "required": ["selector"]
      }
    },
    {
      "name": "browser_type",
      "description": "Type text into a browser input field.",
      "parameters": {
        "type": "object",
        "properties": {
          "selector": { "type": "string", "description": "CSS selector" },
          "textValue": { "type": "string", "description": "Text to type" },
          "clear": { "type": "boolean", "description": "Whether to clear existing content first" }
        },
        "required": ["selector", "textValue"]
      }
    },
    {
      "name": "browser_scroll",
      "description": "Scroll the page or scroll to an element in the browser runtime.",
      "parameters": {
        "type": "object",
        "properties": {
          "selector": { "type": "string", "description": "Optional selector to scroll into view" },
          "scrollAmount": { "type": "number", "description": "Scroll distance in pixels" },
          "direction": {
            "type": "string",
            "description": "Scroll direction",
            "enum": ["up", "down"]
          }
        },
        "required": []
      }
    },
    {
      "name": "browser_wait_for_text",
      "description": "Wait until a text fragment appears in the browser content.",
      "parameters": {
        "type": "object",
        "properties": {
          "waitForText": { "type": "string", "description": "Text to wait for" },
          "timeoutMs": { "type": "number", "description": "Optional timeout in milliseconds" }
        },
        "required": ["waitForText"]
      }
    },
    {
      "name": "browser_extract",
      "description": "Extract visible text from the page or a selected browser element.",
      "parameters": {
        "type": "object",
        "properties": {
          "selector": { "type": "string", "description": "Optional selector to scope extraction" }
        },
        "required": []
      }
    },
    {
      "name": "browser_press_key",
      "description": "Send a keyboard key to the browser runtime.",
      "parameters": {
        "type": "object",
        "properties": {
          "selector": { "type": "string", "description": "Optional selector to focus first" },
          "key": { "type": "string", "description": "Keyboard key to press" }
        },
        "required": ["key"]
      }
    }
  ]
}
